---
import ContactPanel from "@components/ContactPanel.astro";
import PageIntro from "@components/PageIntro.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { profile } from "@data/profile";
---

<BaseLayout title="O mně | Portfolio" description="Kdo jsem, jak přemýšlím a na co se profesně zaměřuji.">
  <PageIntro
    eyebrow="O mně"
    title="Klidný styl práce. Silná orientace na logiku, strukturu a smysl."
    text="Technologie mě zajímají jako systémy, ne jako sbírka trendů. Hledám role a projekty, kde se cení přesné myšlení, profesionální tón a poctivě budovaný technický základ."
    sideLabel="Brno / Czech Republic"
  />

  <section class="section">
    <div class="container split-grid">
      <div class="about-text surface" data-reveal>
        <span class="eyebrow">Kdo jsem</span>
        {profile.about.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <div class="about-side surface" data-reveal>
        <span class="eyebrow">Aktuálně mě formuje</span>
        <ul>
          {profile.currentExploring.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        index="01"
        label="Principy"
        title="Jak přemýšlím o práci."
        text="Nejlépe funguje prostředí, kde má kvalita argument, struktura svůj důvod a design není oddělený od techniky."
      />
      <div class="principles">
        {profile.principles.map((principle) => (
          <article class="surface" data-reveal>
            <h2>{principle.title}</h2>
            <p>{principle.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        index="02"
        label="FAQ"
        title="Krátce pro recruitery a spolupráci."
        text="Nejdůležitější kontext přehledně a bez zbytečného marketingu."
      />
      <div class="faq">
        {profile.recruiterFaq.map((item) => (
          <article class="surface" data-reveal>
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ContactPanel />
    </div>
  </section>
</BaseLayout>

<style>
  .about-text,
  .about-side {
    padding: 1.3rem;
    display: grid;
    gap: 1rem;
  }

  .about-text p,
  .about-side li,
  .principles p,
  .faq p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .about-side ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .about-side li {
    padding-top: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .principles,
  .faq {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .principles article,
  .faq article {
    padding: 1.3rem;
    display: grid;
    gap: 0.8rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 1;
    font-size: 1.55rem;
  }
</style>
