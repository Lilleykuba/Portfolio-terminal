---
import ContactPanel from "@components/ContactPanel.astro";
import PageIntro from "@components/PageIntro.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Timeline from "@components/Timeline.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Zaměření a zkušenosti | Portfolio" description="Aktuální profesní fokus, pracovní směr a způsob, jak propojuji web, systémy a enterprise kontext.">
  <PageIntro
    eyebrow="Zaměření"
    title="HRIT jako současná praxe. Web a cybersecurity jako dlouhodobý směr."
    text="Moje zkušenost je poctivě budovaná, ne nafouknutá. Profesně se opírám o enterprise kontext a vedle toho cíleně rozvíjím technický profil směrem k modernímu webu, systémovému designu a bezpečnostnímu myšlení."
    sideLabel="Pracovní trajektorie"
  />

  <section class="section">
    <div class="container">
      <SectionHeading
        index="01"
        label="Trajektorie"
        title="Zkušenost jako směr, ne jako marketingová legenda."
        text="Současné zaměření je praktické a pravdivé: HRIT, procesní přesnost, kontakt se SAP SuccessFactors, rostoucí technická hloubka a dlouhodobé skládání širšího profilu."
      />
      <Timeline />
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <article class="surface block" data-reveal>
        <span class="eyebrow">Co je pro mě důležité v práci</span>
        <ul>
          <li>jasně definovaný problém a rozumná očekávání</li>
          <li>prostředí, kde se dá přemýšlet do hloubky a učit se bez chaosu</li>
          <li>produkt nebo systém, u kterého záleží na kvalitě provedení</li>
          <li>komunikace, která není agresivní ani mlhavá</li>
        </ul>
      </article>
      <article class="surface block" data-reveal>
        <span class="eyebrow">Kam se chci posouvat</span>
        <ul>
          <li>silnější frontend architektura a moderní produkční weby</li>
          <li>lepší porozumění bezpečnosti webových aplikací</li>
          <li>hlubší práce s Node.js, TypeScriptem a systémovým návrhem</li>
          <li>role, kde se spojuje technika, přesnost a dobrý úsudek</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ContactPanel />
    </div>
  </section>
</BaseLayout>

<style>
  .block {
    padding: 1.3rem;
    display: grid;
    gap: 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  li {
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
  }
</style>
