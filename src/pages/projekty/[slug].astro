---
import { getCollection, render } from "astro:content";

import BaseLayout from "@layouts/BaseLayout.astro";
import { projectCategoryMeta } from "@lib/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const categoryLabel = projectCategoryMeta[project.data.category].label;
const previewStack = project.data.stack.slice(0, 4);
---

<BaseLayout
  title={`${project.data.title} | Projekty`}
  description={project.data.summary}
>
  <section class="section">
    <div class="container detail-grid">
      <div class="headline" data-reveal>
        <a class="back-link" href="/#projects">← Zpět na projekty</a>
        <div class="headline-meta">
          <span class="eyebrow">{categoryLabel} / {project.data.year}</span>
          <span class="status-chip">{project.data.status}</span>
        </div>
        <h1 class="heading-lg">{project.data.title}</h1>
        <p class="lede">{project.data.summary}</p>
        <p class="description">{project.data.description}</p>
        <div class="case-summary" aria-label="Shrnutí případové studie">
          {project.data.problem && (
            <article>
              <span>Problém</span>
              <p>{project.data.problem}</p>
            </article>
          )}
          {project.data.solution && (
            <article>
              <span>Řešení</span>
              <p>{project.data.solution}</p>
            </article>
          )}
          {project.data.impact && (
            <article>
              <span>Signál</span>
              <p>{project.data.impact}</p>
            </article>
          )}
        </div>
        <ul class="stack-list" aria-label="Použitý stack">
          {previewStack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <aside class="surface meta" data-reveal>
        <div class="meta-grid">
          <div>
            <span class="meta-label">Kategorie</span>
            <strong>{categoryLabel}</strong>
          </div>
          <div>
            <span class="meta-label">Role</span>
            <strong>{project.data.role}</strong>
          </div>
          <div>
            <span class="meta-label">Stack</span>
            <strong>{project.data.stack.join(" / ")}</strong>
          </div>
          {project.data.proof && (
            <div>
              <span class="meta-label">Projekt ukazuje</span>
              <strong>{project.data.proof}</strong>
            </div>
          )}
          {project.data.highlights.length > 0 && (
            <div>
              <span class="meta-label">Technické body</span>
              <ul class="meta-list">
                {project.data.highlights.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          )}
          {project.data.learning && (
            <div>
              <span class="meta-label">Co jsem si odnesl</span>
              <strong>{project.data.learning}</strong>
            </div>
          )}
          {project.data.nextStep && (
            <div>
              <span class="meta-label">Další krok</span>
              <strong>{project.data.nextStep}</strong>
            </div>
          )}
        </div>
        <div class="link-group">
          {project.data.github && (
            <a class="button button-secondary" href={project.data.github} target="_blank" rel="noreferrer">
              GitHub
            </a>
          )}
          {project.data.demo && (
            <a class="button button-primary" href={project.data.demo} target="_blank" rel="noreferrer">
              Ukázka
            </a>
          )}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container article-wrap">
      <article class="surface article prose" data-reveal>
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
    gap: 1.2rem;
    align-items: start;
  }

  .headline {
    display: grid;
    gap: 1.05rem;
  }

  .headline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--color-accent);
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(245, 209, 13, 0.24);
    background: rgba(245, 209, 13, 0.09);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .description {
    margin: 0;
    color: var(--color-text-muted);
  }

  .case-summary {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.2rem;
  }

  .case-summary article {
    display: grid;
    grid-template-columns: 7.4rem minmax(0, 1fr);
    gap: 0.8rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .case-summary span {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .case-summary p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .meta,
  .article {
    padding: 1.15rem;
  }

  .meta {
    display: grid;
    gap: 0.6rem;
  }

  .meta-grid {
    display: grid;
    gap: 0;
  }

  .meta-grid > div {
    display: grid;
    gap: 0.3rem;
    padding: 0.9rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .meta-grid > div:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .meta-list li {
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .meta-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.34rem;
    height: 1px;
    background: var(--color-accent);
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .link-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .article-wrap {
    display: grid;
  }

  .stack-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stack-list li {
    padding: 0.28rem 0.46rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .case-summary article {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
