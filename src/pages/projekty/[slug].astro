---
import { getCollection, render } from "astro:content";

import BaseLayout from "@layouts/BaseLayout.astro";
import { projectCategoryMeta } from "@lib/content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const categoryLabel = projectCategoryMeta[project.data.category].label;
const tagsLine = project.data.tags.join(" / ");
---

<BaseLayout
  title={`${project.data.title} | Projekty`}
  description={project.data.summary}
>
  <section class="section">
    <div class="container detail-grid">
      <div class="headline" data-reveal>
        <a class="back-link" href="/#terminal-projects">← Zpět na výběr projektů</a>
        <div class="headline-meta">
          <span class="eyebrow">Projekt / {project.data.year}</span>
          <span class="status-chip">{project.data.status}</span>
        </div>
        <h1 class="heading-lg">{project.data.title}</h1>
        <p class="lede">{project.data.description}</p>
        <p class="tagline">{tagsLine}</p>
      </div>

      <aside class="surface meta" data-reveal>
        <div class="signal">
          <span class="meta-label">Project Signal</span>
          <pre>{`category : ${categoryLabel}
stack    : ${project.data.stack.slice(0, 3).join(" / ")}
role     : ${project.data.role}
status   : ${project.data.status}`}</pre>
        </div>
        <div class="meta-grid">
          {project.data.proof && (
            <div>
              <span class="meta-label">Co projekt ukazuje</span>
              <strong>{project.data.proof}</strong>
            </div>
          )}
          <div>
            <span class="meta-label">Oblast</span>
            <strong>{categoryLabel}</strong>
          </div>
          <div>
            <span class="meta-label">Role</span>
            <strong>{project.data.role}</strong>
          </div>
          <div>
            <span class="meta-label">Stack</span>
            <strong>{project.data.stack.join(" / ")}</strong>
          </div>
          {project.data.learning && (
            <div>
              <span class="meta-label">Co jsem si z projektu odnesl</span>
              <strong>{project.data.learning}</strong>
            </div>
          )}
          {project.data.nextStep && (
            <div>
              <span class="meta-label">Další krok</span>
              <strong>{project.data.nextStep}</strong>
            </div>
          )}
        </div>
        <div class="link-group">
          {project.data.github && (
            <a class="button button-secondary" href={project.data.github} target="_blank" rel="noreferrer">
              GitHub
            </a>
          )}
          {project.data.demo && (
            <a class="button button-primary" href={project.data.demo} target="_blank" rel="noreferrer">
              Ukázka
            </a>
          )}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container article-wrap">
      <article class="surface article prose" data-reveal>
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 1rem;
    align-items: start;
  }

  .headline {
    display: grid;
    gap: 1rem;
  }

  .headline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--color-accent);
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(245, 209, 13, 0.24);
    background: rgba(245, 209, 13, 0.09);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .tagline {
    margin: 0;
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta,
  .article {
    padding: 1.3rem;
  }

  .meta {
    display: grid;
    gap: 1rem;
  }

  .signal {
    display: grid;
    gap: 0.7rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .signal pre {
    margin: 0;
    padding: 0.95rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(0, 0, 0, 0.24);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .meta-grid {
    display: grid;
    gap: 0.95rem;
  }

  .meta-grid > div {
    display: grid;
    gap: 0.3rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .link-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-wrap {
    display: grid;
  }

  @media (max-width: 900px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
