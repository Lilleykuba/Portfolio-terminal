---
import { socialLinks } from "@data/socials";
import { availability } from "@data/site";
import AvailabilityBadge from "./AvailabilityBadge.astro";
---

<section class="contact-panel surface" data-reveal>
  <div class="intro">
    <span class="eyebrow">Kontakt</span>
    <h2 class="heading-md">Pokud hledáte juniorního člověka pro web, cybersecurity nebo HRIT, ozvěte se.</h2>
    <p class="lede">
      Nejvíc mi sedí stručný e-mail nebo LinkedIn zpráva s kontextem role, týmu a toho,
      co má člověk na pozici reálně řešit.
    </p>
    <AvailabilityBadge status={availability.status} note={availability.note} />
  </div>

  <ul class="links" aria-label="Kontaktní odkazy">
    {socialLinks.map((link) => (
      <li>
        {link.available && link.href ? (
          <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noreferrer" : undefined}>
            <span>{link.label}</span>
            <strong>{link.handle}</strong>
          </a>
        ) : (
          <div class="disabled">
            <span>{link.label}</span>
            <strong>{link.handle}</strong>
          </div>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  .contact-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 1rem;
    padding: 1.35rem;
  }

  .intro {
    display: grid;
    gap: 1rem;
  }

  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.8rem;
  }

  li a,
  .disabled {
    display: grid;
    gap: 0.15rem;
    padding: 1rem;
    min-height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    transition:
      transform var(--duration-fast) var(--easing),
      border-color var(--duration-fast) var(--easing),
      background-color var(--duration-fast) var(--easing);
  }

  li a:hover,
  li a:focus-visible {
    transform: translate(-2px, -2px);
    border-color: rgba(245, 209, 13, 0.34);
    background: rgba(245, 209, 13, 0.08);
  }

  span {
    font-family: var(--font-mono);
    color: var(--color-text-soft);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
  }

  strong {
    font-size: 1rem;
  }

  .disabled {
    opacity: 0.62;
  }

  @media (max-width: 840px) {
    .contact-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
