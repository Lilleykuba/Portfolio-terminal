---
import AvailabilityBadge from "@components/AvailabilityBadge.astro";
import { availability, documents } from "@data/site";
import { socialLinks } from "@data/socials";

const emailLink = socialLinks.find((link) => link.label === "E-mail");
const githubLink = socialLinks.find((link) => link.label === "GitHub");
const linkedInLink = socialLinks.find((link) => link.label === "LinkedIn");
const emailHref = emailLink?.href ?? "";
const cvKey = Array.from(documents.cvHref)
  .map((character, index) => character.charCodeAt(0) + 17 + (index % 7))
  .join(".");
const verificationPayload = [
  `SHA-256: ${documents.cvSha256}`,
  `PGP fingerprint: ${documents.cvPgpFingerprint}`,
].join("\n");
---

<section class="recruiter-access" data-reveal>
  <div class="access-shell surface">
    <div class="access-intro">
      <span class="kicker">Kontakt</span>
      <h3>Kontakt bez zbytečného tření.</h3>
      <p class="lede">
        CV otevřu po kliknutí. E-mail je viditelný, profily jsou hned po ruce
        a u CV nechávám i jednoduchý otisk pro ověření souboru.
      </p>
      <AvailabilityBadge status={availability.status} note={availability.note} />
    </div>

    <div class="actions" aria-label="Kontakty a dokumenty">
      {documents.cvHref && (
        <button class="access-card primary" type="button" data-open-cv data-cv-key={cvKey}>
          <span>{documents.cvLabel}</span>
          <strong>{documents.cvNote}</strong>
        </button>
      )}

      {emailHref && (
        <a class="access-card" href={emailHref} data-email-link>
          <span>E-mail</span>
          <strong>{emailLink?.handle}</strong>
        </a>
      )}

      {linkedInLink && (
        <a class="access-card" href={linkedInLink.href} target="_blank" rel="noreferrer">
          <span>LinkedIn</span>
          <strong>{linkedInLink.handle}</strong>
        </a>
      )}

      {githubLink && (
        <a class="access-card" href={githubLink.href} target="_blank" rel="noreferrer">
          <span>GitHub</span>
          <strong>{githubLink.handle}</strong>
        </a>
      )}
    </div>

    <details class="integrity-panel">
      <summary>
        <span>Ověření integrity CV</span>
        <strong>SHA-256 + PGP fingerprint</strong>
      </summary>
      <div class="integrity-body">
        <dl>
          <div>
            <dt>SHA-256</dt>
            <dd>{documents.cvSha256}</dd>
          </div>
          <div>
            <dt>PGP fingerprint</dt>
            <dd>{documents.cvPgpFingerprint}</dd>
          </div>
        </dl>
        <code hidden data-verification-value>{verificationPayload}</code>
        <button type="button" data-copy-verification>
          Kopírovat ověřovací údaje
        </button>
      </div>
    </details>
  </div>
</section>

<script>
  function decodePath(key) {
    return key
      .split(".")
      .filter(Boolean)
      .map((value, index) => String.fromCharCode(Number(value) - 17 - (index % 7)))
      .join("");
  }

  function initCvOpen() {
    document.querySelectorAll("[data-open-cv]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement) || button.dataset.cvBound === "true") return;
      button.dataset.cvBound = "true";

      button.addEventListener("click", () => {
        const path = decodePath(button.dataset.cvKey ?? "");
        if (!path) return;
        window.open(path, "_blank", "noopener,noreferrer");
      });
    });
  }

  function initCvIntegrityCopy() {
    document.querySelectorAll("[data-copy-verification]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement) || button.dataset.bound === "true") return;
      button.dataset.bound = "true";

      button.addEventListener("click", async () => {
        const originalLabel = button.textContent ?? "Kopírovat ověřovací údaje";
        const value = button.parentElement?.querySelector("[data-verification-value]")?.textContent ?? "";

        try {
          await navigator.clipboard.writeText(value);
          button.textContent = "Zkopírováno";
        } catch {
          button.textContent = "Kopírování selhalo";
        }

        window.setTimeout(() => {
          button.textContent = originalLabel;
        }, 1600);
      });
    });
  }

  initCvOpen();
  initCvIntegrityCopy();
  document.addEventListener("astro:page-load", initCvOpen);
  document.addEventListener("astro:page-load", initCvIntegrityCopy);
</script>

<style>
  .recruiter-access {
    display: grid;
  }

  .access-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 1rem;
    padding: 1.15rem;
  }

  .access-intro {
    display: grid;
    gap: 0.85rem;
    align-content: start;
    padding-right: 0.4rem;
  }

  .access-intro h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.45rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .access-card {
    min-height: 8rem;
    display: grid;
    align-content: space-between;
    gap: 0.9rem;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.025);
    color: var(--color-text);
    text-align: left;
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--easing),
      border-color var(--duration-fast) var(--easing),
      background-color var(--duration-fast) var(--easing);
  }

  .access-card.primary {
    border-color: rgba(245, 209, 13, 0.35);
    background: rgba(245, 209, 13, 0.09);
  }

  .access-card:hover,
  .access-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(245, 209, 13, 0.32);
    background: rgba(245, 209, 13, 0.065);
  }

  .access-card span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-soft);
  }

  .access-card strong {
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .integrity-panel {
    grid-column: 1 / -1;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .integrity-panel summary {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 1rem;
    align-items: center;
    cursor: pointer;
    list-style: none;
  }

  .integrity-panel summary::-webkit-details-marker {
    display: none;
  }

  .integrity-panel summary span,
  .integrity-body dt,
  .integrity-body button {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .integrity-panel summary span {
    color: var(--color-accent);
  }

  .integrity-panel summary strong {
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .integrity-body {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.9rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .integrity-body dl {
    display: grid;
    gap: 0.7rem;
    margin: 0;
  }

  .integrity-body div {
    display: grid;
    grid-template-columns: minmax(130px, 0.28fr) minmax(0, 1fr);
    gap: 0.8rem;
  }

  .integrity-body dt {
    color: var(--color-text-soft);
  }

  .integrity-body dd {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    overflow-wrap: anywhere;
  }

  .integrity-body button {
    justify-self: start;
    min-height: 2.35rem;
    padding: 0.55rem 0.72rem;
    border: 1px solid rgba(245, 209, 13, 0.22);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text);
    cursor: pointer;
  }

  .integrity-body button:hover,
  .integrity-body button:focus-visible {
    color: var(--color-accent);
    border-color: rgba(245, 209, 13, 0.34);
  }

  @media (max-width: 860px) {
    .access-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .actions {
      grid-template-columns: 1fr;
    }

    .access-card {
      min-height: 6.6rem;
    }

    .integrity-panel summary,
    .integrity-body div {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
