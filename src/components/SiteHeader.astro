---
import { navigation } from "@data/navigation";
import { profile } from "@data/profile";

const currentPath = Astro.url.pathname;
const initials = profile.name
  .split(" ")
  .filter(Boolean)
  .map((part) => part[0]?.toUpperCase())
  .slice(0, 2)
  .join(" / ");
---

<header class="site-header">
  <div class="container inner">
    <a class="brand" href="/">
      <span class="monogram" aria-hidden="true">{initials}</span>
      <span class="label">
        <strong>{profile.name}</strong>
        <span>{profile.heroHeadline.lead}</span>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Hlavní navigace">
      {navigation.map((item) => {
        const active =
          item.href === "/"
            ? currentPath === item.href
            : item.href.startsWith("/#")
              ? false
              : currentPath.startsWith(item.href);
        const accent = item.href === "/#contact";

        return (
          <a class:list={["nav-link", accent && "accent-link", active && "active"]} href={item.href}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobilní navigace">
        {navigation.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>

<script>
  function initMobileNav() {
    const mobileNav = document.querySelector(".mobile-nav");
    if (!mobileNav || mobileNav.dataset.bound === "true") {
      return;
    }

    const mobileLinks = mobileNav?.querySelectorAll("a");
    mobileNav.dataset.bound = "true";

    mobileLinks?.forEach((link) => {
      link.addEventListener("click", () => {
        mobileNav?.removeAttribute("open");
      });
    });
  }

  initMobileNav();
  document.addEventListener("astro:page-load", initMobileNav);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 0;
    backdrop-filter: blur(18px);
    background: rgba(9, 9, 9, 0.86);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-width: 0;
    min-height: 5.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    min-width: 0;
    flex: 0 1 auto;
  }

  .monogram {
    display: grid;
    place-items: center;
    width: 2.9rem;
    aspect-ratio: 1;
    border-radius: 0.45rem;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-display);
    font-weight: 900;
    box-shadow: 0.18rem 0.18rem 0 0 rgba(245, 209, 13, 0.12);
  }

  .label {
    display: grid;
    min-width: 0;
  }

  .label strong,
  .label span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .label strong {
    font-size: 1.55rem;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .label span {
    color: var(--color-text-soft);
    font-size: 0.92rem;
    margin-top: 0.15rem;
  }

  .desktop-nav {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    min-width: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.6rem;
    padding: 0.2rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition:
      transform var(--duration-fast) var(--easing),
      color var(--duration-fast) var(--easing);
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.4rem;
    height: 1px;
    background: rgba(245, 209, 13, 0.72);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--duration-fast) var(--easing);
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.active {
    color: var(--color-text);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    transform: translateY(-1px);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .accent-link {
    color: var(--color-accent);
  }

  .mobile-nav {
    display: none;
    position: relative;
  }

  .mobile-nav summary {
    list-style: none;
    cursor: pointer;
    padding: 0.72rem 0.95rem;
    border: 1px solid rgba(245, 209, 13, 0.24);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.76rem;
  }

  .mobile-nav[open] nav {
    position: absolute;
    right: 0;
    top: calc(100% + 0.6rem);
    min-width: 220px;
    padding: 0.6rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(245, 209, 13, 0.2);
    background: rgba(9, 9, 9, 0.96);
    display: grid;
    gap: 0.3rem;
  }

  .mobile-nav nav a {
    padding: 0.8rem;
    border-radius: var(--radius-sm);
  }

  .mobile-nav nav a:hover,
  .mobile-nav nav a:focus-visible {
    background: rgba(245, 209, 13, 0.12);
  }

  @media (max-width: 920px) {
    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }

  @media (max-width: 1120px) {
    .nav-link {
      font-size: 0.92rem;
    }
  }

  @media (max-width: 580px) {
    .inner {
      min-height: 4.7rem;
    }

    .monogram {
      width: 2.55rem;
    }

    .label strong {
      font-size: 1.22rem;
    }

    .label span {
      font-size: 0.78rem;
    }
  }
</style>
