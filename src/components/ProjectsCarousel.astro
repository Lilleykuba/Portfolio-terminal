---
import type { CollectionEntry } from "astro:content";

import { projectCategoryMeta } from "@lib/content";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<section class="projects-carousel" data-projects-carousel data-reveal>
  <div class="carousel-head">
    <div>
      <span class="kicker">Vybrané práce</span>
    </div>
    <div class="carousel-controls" aria-label="Ovládání projektů">
      <span class="carousel-count" data-carousel-count>
        01 / {String(projects.length).padStart(2, "0")}
      </span>
      <button type="button" data-carousel-prev aria-label="Předchozí projekt">←</button>
      <button type="button" data-carousel-next aria-label="Další projekt">→</button>
    </div>
  </div>

  <div class="rail-shell">
    <div class="rail" data-carousel-rail tabindex="0" aria-label="Seznam projektů">
      {projects.map((project) => {
        const categoryLabel = projectCategoryMeta[project.data.category].label;
        const previewStack = project.data.stack.slice(0, 4);

        return (
          <article class="project-card surface" data-project-card>
            <div class="card-topline">
              <span>{categoryLabel}</span>
              <span>{project.data.year}</span>
              <span>{project.data.status}</span>
            </div>

            <div class="card-body">
              <h3>{project.data.title}</h3>
              <p>{project.data.summary}</p>
            </div>

            <p class="project-role">{project.data.role}</p>

            <ul class="stack-list" aria-label="Použitý stack">
              {previewStack.map((item) => (
                <li>{item}</li>
              ))}
            </ul>

            <div class="card-actions">
              <a class="card-link strong" href={`/projekty/${project.id}/`}>Detail</a>
              {project.data.demo && (
                <button
                  class="card-link"
                  type="button"
                  data-preview-title={project.data.title}
                  data-preview-url={project.data.demo}
                >
                  Live ukázka
                </button>
              )}
              {project.data.github && (
                <a class="card-link" href={project.data.github} target="_blank" rel="noreferrer">
                  GitHub
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>

  <dialog class="preview-dialog" data-preview-dialog>
    <div class="preview-shell surface">
      <div class="preview-topline">
        <div>
          <span class="kicker">Live ukázka</span>
          <h3 data-preview-heading>Náhled projektu</h3>
        </div>
        <div class="preview-actions">
          <a class="card-link" href="#" target="_blank" rel="noreferrer" data-preview-link>
            Otevřít venku
          </a>
          <button class="preview-close" type="button" data-preview-close aria-label="Zavřít náhled">
            ×
          </button>
        </div>
      </div>
      <div class="preview-frame-wrap">
        <iframe
          title="Live náhled projektu"
          loading="lazy"
          referrerpolicy="no-referrer"
          sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
          data-preview-frame
        ></iframe>
      </div>
    </div>
  </dialog>
</section>

<script>
  function initProjectCarousel() {
    document.querySelectorAll("[data-projects-carousel]").forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.bound === "true") return;
      root.dataset.bound = "true";

      const rail = root.querySelector("[data-carousel-rail]");
      const prev = root.querySelector("[data-carousel-prev]");
      const next = root.querySelector("[data-carousel-next]");
      const count = root.querySelector("[data-carousel-count]");
      const cards = Array.from(root.querySelectorAll("[data-project-card]"));
      const dialog = root.querySelector("[data-preview-dialog]");
      const frame = root.querySelector("[data-preview-frame]");
      const heading = root.querySelector("[data-preview-heading]");
      const previewLink = root.querySelector("[data-preview-link]");
      const close = root.querySelector("[data-preview-close]");
      const previewTriggers = root.querySelectorAll("[data-preview-url]");
      const total = cards.length;

      if (!(rail instanceof HTMLElement) || total === 0) return;

      const format = (value) => String(value).padStart(2, "0");

      const getStep = () => {
        const firstCard = cards[0];
        if (!(firstCard instanceof HTMLElement)) return rail.clientWidth;
        const styles = window.getComputedStyle(rail);
        const gap = Number.parseFloat(styles.columnGap || styles.gap || "0");
        return firstCard.offsetWidth + gap;
      };

      const getActiveIndex = () => {
        const step = getStep();
        if (!step) return 0;
        return Math.min(total - 1, Math.max(0, Math.round(rail.scrollLeft / step)));
      };

      const update = () => {
        const index = getActiveIndex();
        if (count instanceof HTMLElement) {
          count.textContent = `${format(index + 1)} / ${format(total)}`;
        }
        if (prev instanceof HTMLButtonElement) prev.disabled = index === 0;
        if (next instanceof HTMLButtonElement) next.disabled = index === total - 1;
      };

      const goTo = (index) => {
        const target = Math.min(total - 1, Math.max(0, index));
        rail.scrollTo({ left: getStep() * target, behavior: "smooth" });
      };

      if (prev instanceof HTMLButtonElement) {
        prev.addEventListener("click", () => goTo(getActiveIndex() - 1));
      }

      if (next instanceof HTMLButtonElement) {
        next.addEventListener("click", () => goTo(getActiveIndex() + 1));
      }

      rail.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          goTo(getActiveIndex() - 1);
        }

        if (event.key === "ArrowRight") {
          event.preventDefault();
          goTo(getActiveIndex() + 1);
        }
      });

      rail.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);

      const closePreview = () => {
        if (!(dialog instanceof HTMLDialogElement)) return;
        dialog.close();
        if (frame instanceof HTMLIFrameElement) frame.src = "";
      };

      const openPreview = (title, url) => {
        if (
          !(dialog instanceof HTMLDialogElement) ||
          !(frame instanceof HTMLIFrameElement) ||
          !(heading instanceof HTMLElement) ||
          !(previewLink instanceof HTMLAnchorElement)
        ) return;

        heading.textContent = title;
        frame.src = url;
        previewLink.href = url;
        if (!dialog.open) dialog.showModal();
      };

      previewTriggers.forEach((trigger) => {
        if (!(trigger instanceof HTMLButtonElement)) return;
        trigger.addEventListener("click", () => {
          const title = trigger.dataset.previewTitle ?? "Náhled projektu";
          const url = trigger.dataset.previewUrl ?? "";
          if (url) openPreview(title, url);
        });
      });

      if (close instanceof HTMLButtonElement) {
        close.addEventListener("click", closePreview);
      }

      if (dialog instanceof HTMLDialogElement) {
        dialog.addEventListener("click", (event) => {
          if (event.target === dialog) closePreview();
        });
        dialog.addEventListener("close", () => {
          if (frame instanceof HTMLIFrameElement) frame.src = "";
        });
        dialog.addEventListener("cancel", () => {
          if (frame instanceof HTMLIFrameElement) frame.src = "";
        });
      }

      update();
    });
  }

  initProjectCarousel();
  document.addEventListener("astro:page-load", initProjectCarousel);
</script>

<style>
  .projects-carousel {
    display: grid;
    gap: 0.9rem;
  }

  .carousel-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .carousel-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .carousel-count {
    min-width: 4.8rem;
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .carousel-controls button {
    display: grid;
    place-items: center;
    width: 2.35rem;
    aspect-ratio: 1;
    border: 1px solid rgba(245, 209, 13, 0.22);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--easing),
      border-color var(--duration-fast) var(--easing),
      background-color var(--duration-fast) var(--easing),
      transform var(--duration-fast) var(--easing);
  }

  .carousel-controls button:hover,
  .carousel-controls button:focus-visible {
    color: var(--color-accent);
    border-color: rgba(245, 209, 13, 0.38);
    background: rgba(245, 209, 13, 0.06);
    transform: translateY(-1px);
  }

  .carousel-controls button:disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .rail-shell {
    overflow: hidden;
    position: relative;
  }

  .rail-shell::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0.55rem;
    width: clamp(2rem, 7vw, 5rem);
    pointer-events: none;
    background: linear-gradient(270deg, var(--color-bg), transparent);
  }

  .rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(620px, 78vw, 820px);
    gap: 1rem;
    overflow-x: auto;
    padding: 0.1rem clamp(2rem, 12vw, 10rem) 0.7rem 0.1rem;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0.1rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .rail::-webkit-scrollbar {
    display: none;
  }

  .project-card {
    min-height: 22rem;
    display: grid;
    grid-template-rows: auto 1fr auto auto auto;
    gap: 1rem;
    padding: clamp(1rem, 2.5vw, 1.35rem);
    scroll-snap-align: start;
    scroll-snap-stop: always;
    background:
      linear-gradient(135deg, rgba(245, 209, 13, 0.07), transparent 34%),
      var(--color-panel-alt);
  }

  .card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .card-topline span,
  .stack-list li,
  .card-link {
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
  }

  .card-topline span {
    padding: 0.24rem 0.44rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.025);
  }

  .card-body {
    display: grid;
    gap: 0.65rem;
    align-content: center;
    max-width: 52rem;
  }

  .card-body h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.1vw, 3.45rem);
    line-height: 1.02;
    letter-spacing: 0;
    max-width: 13ch;
  }

  .card-body p,
  .project-role {
    margin: 0;
    color: var(--color-text-muted);
  }

  .card-body p {
    max-width: 54ch;
    font-size: clamp(1rem, 1.4vw, 1.1rem);
  }

  .project-role {
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .stack-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stack-list li {
    padding: 0.28rem 0.46rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
  }

  .card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.52rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--easing),
      border-color var(--duration-fast) var(--easing),
      background-color var(--duration-fast) var(--easing);
  }

  .card-link.strong {
    color: var(--color-accent);
  }

  .card-link:hover,
  .card-link:focus-visible {
    color: var(--color-accent);
    border-color: rgba(245, 209, 13, 0.24);
    background: rgba(245, 209, 13, 0.055);
  }

  .preview-dialog {
    width: min(1120px, calc(100vw - 2rem));
    max-width: none;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .preview-dialog::backdrop {
    background: rgba(0, 0, 0, 0.76);
    backdrop-filter: blur(4px);
  }

  .preview-shell {
    padding: clamp(0.75rem, 2vw, 1rem);
  }

  .preview-topline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    margin-bottom: 0.85rem;
  }

  .preview-topline h3 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .preview-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .preview-close {
    display: grid;
    place-items: center;
    width: 2.35rem;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
  }

  .preview-frame-wrap {
    aspect-ratio: 16 / 9.4;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0a0a0a;
  }

  .preview-frame-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #111;
  }

  @media (max-width: 720px) {
    .carousel-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .rail {
      grid-auto-columns: minmax(292px, 88vw);
      padding-right: 0.25rem;
    }

    .rail-shell::after {
      display: none;
    }

    .project-card {
      min-height: 24rem;
    }

    .preview-dialog {
      width: calc(100vw - 1rem);
    }

    .preview-topline {
      flex-direction: column;
    }

    .preview-actions {
      width: 100%;
      justify-content: space-between;
    }

    .preview-frame-wrap {
      aspect-ratio: 10 / 13;
    }
  }
</style>
