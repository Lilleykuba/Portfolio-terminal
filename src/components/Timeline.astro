---
import { profile } from "@data/profile";
---

<ol class="timeline">
  {profile.timeline.map((item, index) => (
    <li class="surface" data-reveal>
      <div class="marker" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
      <div class="content">
        <span class="year">{item.year}</span>
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </div>
    </li>
  ))}
</ol>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  li {
    display: grid;
    grid-template-columns: minmax(60px, 88px) minmax(0, 1fr);
    gap: 1rem;
    padding: 1.25rem;
  }

  .marker {
    display: grid;
    place-items: start;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.14em;
  }

  .content {
    display: grid;
    gap: 0.4rem;
  }

  .year {
    font-family: var(--font-mono);
    color: var(--color-text-soft);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.04em;
  }

  p {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    li {
      grid-template-columns: 1fr;
    }
  }
</style>
