---
import type { CollectionEntry } from "astro:content";

import { projectCategoryMeta } from "@lib/content";

interface Props {
  project: CollectionEntry<"projects">;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
const categoryLabel = projectCategoryMeta[project.data.category].label;
const previewStack = project.data.stack.slice(0, 3);
---

<article
  class:list={["project-card", "surface", featured && "featured"]}
  data-reveal
>
  <div class="topline">
    <span class="category">{categoryLabel}</span>
    <div class="meta-inline">
      <span class="year">{project.data.year}</span>
      <span class="status">{project.data.status}</span>
    </div>
  </div>
  <div class="copy">
    <h3><a href={`/projekty/${project.id}/`}>{project.data.title}</a></h3>
    <p>{project.data.summary}</p>
  </div>
  <ul class="stack-list" aria-label="Použitý stack">
    {previewStack.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <div class="meta-band" aria-label="Detaily projektu">
    <span>{project.data.role}</span>
  </div>
  <div class="bottom">
    <div class="actions">
      {project.data.github && (
        <a class="mini-link" href={project.data.github} target="_blank" rel="noreferrer">
          GitHub
        </a>
      )}
      {project.data.demo && (
        <a class="mini-link strong" href={project.data.demo} target="_blank" rel="noreferrer">
          Ukázka
        </a>
      )}
      <a class="detail-link" href={`/projekty/${project.id}/`}>
        Detail
      </a>
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    gap: 0.85rem;
    padding: 1.05rem;
    min-height: 100%;
  }

  .topline {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .meta-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .category,
  .year,
  .status,
  .mini-link,
  .stack-list li {
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.7rem;
  }

  .project-card.featured {
    background:
      linear-gradient(180deg, rgba(245, 209, 13, 0.045), transparent 28%),
      var(--color-panel-alt);
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .status {
    color: var(--color-accent);
  }

  .copy {
    display: grid;
    gap: 0.45rem;
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
    font-size: clamp(1.18rem, 2vw, 1.48rem);
    line-height: 1.02;
  }

  h3 a {
    transition: color var(--duration-fast) var(--easing);
  }

  h3 a:hover,
  h3 a:focus-visible {
    color: var(--color-accent);
  }

  p {
    margin: 0;
    color: var(--color-text-muted);
  }

  .stack-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .stack-list li {
    padding: 0.28rem 0.46rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
  }

  .meta-band {
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .mini-link {
    transition: color var(--duration-fast) var(--easing);
  }

  .mini-link:hover,
  .mini-link:focus-visible {
    color: var(--color-accent);
  }

  .mini-link.strong {
    color: var(--color-accent);
  }

  .detail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
  }

  .detail-link::after {
    content: "→";
    transition: transform var(--duration-fast) var(--easing);
  }

  .detail-link:hover::after,
  .detail-link:focus-visible::after {
    transform: translateX(4px);
  }

  @media (max-width: 620px) {
    .bottom {
      align-items: start;
    }

    .actions {
      justify-content: flex-start;
    }
  }
</style>
