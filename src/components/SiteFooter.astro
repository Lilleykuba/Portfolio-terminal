---
import { availability } from "@data/site";
import { profile } from "@data/profile";
import { socialLinks } from "@data/socials";
import { documents } from "@data/site";

const linkedIn = socialLinks.find((link) => link.label === "LinkedIn" && link.available);
const github = socialLinks.find((link) => link.label === "GitHub" && link.available);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <section class="footer-segment identity">
      <span class="segment-label">Profil</span>
      <p class="name">{profile.name}</p>
      <p class="statement">{profile.location}</p>
      <p class="profile-note">{availability.status}</p>
    </section>

    <section class="footer-segment pgp-segment">
      <span class="segment-label">CV / PGP</span>
      <p class="pgp-copyline">Pro otevření CV lze použít veřejný klíč nebo fingerprint.</p>
      <p class="pgp-fingerprint">{documents.cvPgpFingerprint}</p>
      <details class="pgp-details">
        <summary>Zobrazit veřejný klíč</summary>
        <pre class="pgp-key" data-pgp-key>{documents.cvPgpPublicKey}</pre>
      </details>
      <button class="pgp-copy" type="button" data-copy-pgp>
        Kopírovat veřejný klíč
      </button>
    </section>

    <nav class="footer-segment footer-links" aria-label="Footer links">
      <span class="segment-label">Odkazy</span>
      <a href="/#contact">Kontakt</a>
      {linkedIn && (
        <a href={linkedIn.href} target="_blank" rel="noreferrer">
          LinkedIn
        </a>
      )}
      {github && (
        <a href={github.href} target="_blank" rel="noreferrer">
          GitHub
        </a>
      )}
    </nav>
  </div>
</footer>

<script>
  function initPgpCopy() {
    const button = document.querySelector("[data-copy-pgp]");
    const keyBlock = document.querySelector("[data-pgp-key]");
    if (!(button instanceof HTMLButtonElement) || !(keyBlock instanceof HTMLElement)) return;
    if (button.dataset.bound === "true") return;
    button.dataset.bound = "true";

    button.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(keyBlock.textContent ?? "");
        button.textContent = "Zkopírováno";
        window.setTimeout(() => {
          button.textContent = "Kopírovat veřejný klíč";
        }, 1600);
      } catch {
        button.textContent = "Kopírování se nepovedlo";
      }
    });
  }

  initPgpCopy();
  document.addEventListener("astro:page-load", initPgpCopy);
</script>

<style>
  .site-footer {
    padding: 1.45rem 0 2.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.2fr) minmax(0, 0.9fr);
    gap: 0.9rem;
    align-items: stretch;
  }

  .footer-segment {
    display: grid;
    gap: 0.36rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.015);
    min-width: 0;
  }

  .segment-label {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .identity {
    align-content: start;
  }

  .name {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .statement {
    margin: 0;
    color: var(--color-text-muted);
  }

  .profile-note,
  .footer-links {
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--color-text-soft);
  }

  .profile-note {
    margin: 0.2rem 0 0;
  }

  .footer-links {
    align-content: start;
  }

  .footer-links a {
    padding-top: 0.45rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .pgp-segment {
    gap: 0.55rem;
  }

  .pgp-copyline {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .pgp-fingerprint {
    margin: 0;
    font-family: var(--font-mono);
    color: var(--color-text);
    letter-spacing: 0.08em;
  }

  .pgp-details summary {
    cursor: pointer;
    font-family: var(--font-mono);
    color: var(--color-text-soft);
  }

  .pgp-key {
    margin: 0.75rem 0 0;
    padding: 0.9rem;
    max-height: 11rem;
    overflow: auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .pgp-copy {
    justify-self: start;
    padding: 0.58rem 0.8rem;
    border: 1px solid rgba(245, 209, 13, 0.22);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
