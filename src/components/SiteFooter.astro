---
import { availability, documents } from "@data/site";
import { profile } from "@data/profile";
import { socialLinks } from "@data/socials";

const linkedIn = socialLinks.find((link) => link.label === "LinkedIn" && link.available);
const github = socialLinks.find((link) => link.label === "GitHub" && link.available);
const email = socialLinks.find((link) => link.label === "E-mail" && link.available);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <section class="footer-segment identity">
      <span class="segment-label">Profil</span>
      <p class="name">{profile.name}</p>
      <p class="statement">{profile.location}</p>
      <p class="profile-note">{availability.status}</p>
    </section>

    <section class="footer-segment">
      <span class="segment-label">Rychlý signál</span>
      <p class="statement">
        Junior IT profil pro cybersecurity, systémy, networking, HRIT a technické
        webové projekty.
      </p>
      {documents.cvHref && <a class="footer-cta" href="/#contact">Kontakt / CV</a>}
    </section>

    <nav class="footer-segment footer-links" aria-label="Footer links">
      <span class="segment-label">Odkazy</span>
      <a href="/#contact">Kontakt</a>
      {email && <a href={email.href}>E-mail</a>}
      {linkedIn && (
        <a href={linkedIn.href} target="_blank" rel="noreferrer">
          LinkedIn
        </a>
      )}
      {github && (
        <a href={github.href} target="_blank" rel="noreferrer">
          GitHub
        </a>
      )}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    padding: 1.45rem 0 2.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr) minmax(0, 0.9fr);
    gap: 0.9rem;
    align-items: stretch;
  }

  .footer-segment {
    display: grid;
    gap: 0.46rem;
    align-content: start;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.015);
    min-width: 0;
  }

  .segment-label {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .name {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .statement {
    margin: 0;
    color: var(--color-text-muted);
  }

  .profile-note,
  .footer-links,
  .footer-cta {
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--color-text-soft);
  }

  .profile-note {
    margin: 0.2rem 0 0;
  }

  .footer-links a,
  .footer-cta {
    padding-top: 0.45rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-links a:hover,
  .footer-links a:focus-visible,
  .footer-cta:hover,
  .footer-cta:focus-visible {
    color: var(--color-accent);
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
